{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/openclaw-mock-data.schema.json",
  "title": "OpenClaw mock data v1",
  "$comment": "Cross-reference constraints such as evidenceIds referring to evidenceItems are validated by review/check scripts, not fully by this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "workspace",
    "project",
    "contextNodes",
    "selectedContext",
    "specTemplates",
    "specDraft",
    "specFields",
    "reviewRuns",
    "findings",
    "decisions",
    "evidenceItems",
    "artifactRefs",
    "workPackets",
    "handoffPackets",
    "agentRoles",
    "validationResults",
    "qaGates",
    "visualBaselines"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "fixtureStatus",
        "createdAt"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "fixtureStatus": {
          "enum": [
            "candidate",
            "approved",
            "deprecated"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "contextNodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contextNode"
      }
    },
    "selectedContext": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2,8}-[0-9]{3}$"
      }
    },
    "specTemplates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/specTemplate"
      }
    },
    "specDraft": {
      "$ref": "#/$defs/specDraft"
    },
    "specFields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/specField"
      }
    },
    "reviewRuns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/reviewRun"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "evidenceItems": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceItem"
      }
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactRef"
      }
    },
    "workPackets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workPacket"
      }
    },
    "handoffPackets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/handoffPacket"
      }
    },
    "agentRoles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agentRole"
      }
    },
    "validationResults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validationResult"
      }
    },
    "qaGates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/qaGate"
      }
    },
    "visualBaselines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/visualBaseline"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]{2,8}-[0-9]{3}$"
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "archived"
          ]
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "workspaceId",
        "name",
        "status",
        "owner"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "workspaceId": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "paused",
            "archived"
          ]
        },
        "owner": {
          "type": "string"
        }
      }
    },
    "contextNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "projectId",
        "type",
        "title",
        "status",
        "riskLevel"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "projectId": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "product_context",
            "design_direction",
            "protected_surface",
            "qa_evidence",
            "source_note"
          ]
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": [
            "included",
            "excluded",
            "protected"
          ]
        },
        "riskLevel": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        }
      }
    },
    "specTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "available",
            "deprecated"
          ]
        }
      }
    },
    "specDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "projectId",
        "templateId",
        "title",
        "status",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "projectId": {
          "$ref": "#/$defs/id"
        },
        "templateId": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "valid",
            "invalid",
            "locked"
          ]
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "specField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "specId",
        "label",
        "value",
        "required",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "specId": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "unresolved",
            "suggested",
            "locked"
          ]
        }
      }
    },
    "reviewRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "specId",
        "reviewer",
        "status",
        "result",
        "startedAt",
        "endedAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "specId": {
          "$ref": "#/$defs/id"
        },
        "reviewer": {
          "type": "string"
        },
        "status": {
          "enum": [
            "queued",
            "inspected",
            "closed"
          ]
        },
        "result": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "not_reviewed"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "reviewRunId",
        "title",
        "severity",
        "status",
        "evidenceIds"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "reviewRunId": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "status": {
          "enum": [
            "open",
            "acknowledged",
            "deferred",
            "resolved"
          ]
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "lockedBy",
        "lockedAt",
        "evidenceIds",
        "rationale"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pending_point_lock",
            "locked",
            "deferred"
          ]
        },
        "lockedBy": {
          "type": [
            "string",
            "null"
          ]
        },
        "lockedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "evidenceIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "projectId",
        "type",
        "title",
        "status",
        "sourceObjectId",
        "targetObjectId",
        "summary",
        "createdAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "projectId": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "doc",
            "visual",
            "fixture",
            "validation",
            "screenshot",
            "code"
          ]
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": [
            "complete",
            "incomplete",
            "warning",
            "missing"
          ]
        },
        "sourceObjectId": {
          "$ref": "#/$defs/id"
        },
        "targetObjectId": {
          "$ref": "#/$defs/id"
        },
        "summary": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "projectId",
        "type",
        "path",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "projectId": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "zip_package",
            "validation_log",
            "screenshot",
            "doc",
            "mock_fixture"
          ]
        },
        "path": {
          "type": "string"
        },
        "status": {
          "enum": [
            "candidate",
            "available",
            "missing",
            "approved"
          ]
        }
      }
    },
    "workPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "projectId",
        "title",
        "status",
        "goalId",
        "artifactRefIds"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "projectId": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "ready",
            "blocked",
            "locked"
          ]
        },
        "goalId": {
          "type": "string",
          "pattern": "^GOAL-DS-[0-9]{3}[A-Z]?$"
        },
        "artifactRefIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "handoffPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "workPacketId",
        "title",
        "status",
        "lockedBy"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "workPacketId": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "ready",
            "locked"
          ]
        },
        "lockedBy": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "agentRole": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "allowedScope"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "inactive"
          ]
        },
        "allowedScope": {
          "type": "string"
        }
      }
    },
    "validationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "checkedAt",
        "summary"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "not_run"
          ]
        },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "qaGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "requiredEvidenceIds",
        "summary"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "pending"
          ]
        },
        "requiredEvidenceIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "visualBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "screenId",
        "viewport",
        "state",
        "artifactPath",
        "status",
        "capturedAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "screenId": {
          "type": "string",
          "pattern": "^screen-[0-9]{3}$"
        },
        "viewport": {
          "enum": [
            "760px",
            "1080px",
            "1180px",
            "1280px"
          ]
        },
        "state": {
          "type": "string"
        },
        "artifactPath": {
          "type": "string"
        },
        "status": {
          "enum": [
            "candidate",
            "approved",
            "needs_review",
            "blocked"
          ]
        },
        "capturedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  },
  "examples": [
    {
